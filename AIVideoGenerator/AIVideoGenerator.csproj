<Project Sdk="Microsoft.NET.Sdk.Web">

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<Nullable>enable</Nullable>
		<ImplicitUsings>enable</ImplicitUsings>
		<!-- Configure build-time OpenAPI generation to produce an OpenAPI 3.1 document -->
		<OpenApiGenerateDocumentsOptions>--openapi-version OpenApi3_1</OpenApiGenerateDocumentsOptions>
		<UserSecretsId>f4a42e49-8eb1-45af-a1e2-3c6ca2e87389</UserSecretsId>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="Azure.AI.OpenAI" Version="2.8.0-beta.1" />
		<PackageReference Include="Azure.Identity" Version="1.19.0" />
		<PackageReference Include="Microsoft.Agents.AI.Workflows" Version="1.0.0-rc4" />
		<PackageReference Include="Microsoft.AspNetCore.OpenApi" Version="10.0.3" />
		<PackageReference Include="Microsoft.Extensions.AI.OpenAI" Version="10.4.0" />
		<PackageReference Include="OllamaSharp" Version="5.4.12" />
		<PackageReference Include="Scalar.AspNetCore" Version="2.13.8" />
		<PackageReference Include="Xabe.FFmpeg" Version="6.0.2" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\AIVideoGenerator.Core\AIVideoGenerator.Core.csproj" />
	</ItemGroup>

</Project>
